# =============================================================================
# .env.example — Template biến môi trường cho Project Vietlife
# =============================================================================
# HƯỚNG DẪN:
#   1. Copy file này thành .env:  cp .env.example .env
#   2. Điền giá trị thật vào file .env
#   3. File .env được liệt kê trong .gitignore → KHÔNG BAO GIỜ bị commit
#   4. Chia sẻ credentials qua kênh bảo mật (Zalo riêng, 1Password, v.v.)
# =============================================================================

# ─── FACEBOOK API ─────────────────────────────────────────────────────────────
# Lấy tại: https://developers.facebook.com → Tools → Graph API Explorer
FB_ACCESS_TOKEN=your_facebook_access_token_here

# ─── GOOGLE CLOUD PLATFORM ────────────────────────────────────────────────────
GCP_PROJECT_ID=gen-lang-client-0738410622
BQ_DATASET=marketing_data
BQ_TABLE=fb_ad_insights

# Đường dẫn tới Service Account JSON (để NGOÀI thư mục repo)
# Ví dụ: /Users/ten-ban/secrets/vietlife-sa.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
